{
  "name": "universal-resource-collector",
  "version": "0.2.0",
  "description": "公开网页文章与多网盘链接整理工具",
  "main": "src/main.js",
  "author": "20051010su-coder",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "test": "node --test tests/*.test.js",
    "dist": "electron-builder --win portable"
  },
  "dependencies": {
    "exceljs": "^4.4.0"
  },
  "devDependencies": {
    "electron": "^37.10.3",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "cn.cangzhiku.resourcecollector",
    "productName": "通用资源采集助手",
    "asar": true,
    "files": [
      "src/**/*",
      "assets/app-icon.png",
      "assets/app-icon.ico",
      "package.json"
    ],
    "win": {
      "icon": "assets/app-icon.ico",
      "signAndEditExecutable": false,
      "target": ["portable"]
    },
    "portable": {
      "artifactName": "通用资源采集助手-${version}-便携版.${ext}"
    }
  }
}
